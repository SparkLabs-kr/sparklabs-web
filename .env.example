# Public site URL (used for OG, sitemap, etc.)
# Use the staging Vercel URL before DNS cutover, then switch to https://www.sparklabs.co.kr
NEXT_PUBLIC_SITE_URL=https://www.sparklabs.co.kr

# Optional: analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ─── Contact form (Resend + Notion) ─────────────────────────────────────────
# Get from https://resend.com/api-keys
RESEND_API_KEY=
# Verified sending domain/sender on Resend
CONTACT_FROM_EMAIL=notifications@sparklabs.co.kr
# Fallback inbox if category routing fails
CONTACT_INBOX_EMAIL=hello@sparklabs.co.kr
# Per-category routing inboxes
CONTACT_INBOX_FOUNDERS=apply@sparklabs.co.kr
CONTACT_INBOX_PARTNERSHIP=partnership@sparklabs.co.kr
CONTACT_INBOX_PRESS=press@sparklabs.co.kr
CONTACT_INBOX_GENERAL=hello@sparklabs.co.kr

# Notion internal integration token — https://www.notion.so/my-integrations
NOTION_TOKEN=
# Target Notion database ID (from DB URL). Database must include the following
# properties:
#   Name (title), Email (email), Organization (rich_text), Category (select),
#   Subject (rich_text), Locale (select), SubmittedAt (date), Status (select)
NOTION_CONTACT_DATABASE_ID=
